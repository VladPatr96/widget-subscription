<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WidgetSubscription.App.App"
             RequestedThemeVariant="Default">
  <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" force a theme variant. -->

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
