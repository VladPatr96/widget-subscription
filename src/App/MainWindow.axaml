<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WidgetSubscription.App.MainWindow"
        Width="320" Height="180"
        Title="Widget Subscription">
  <StackPanel Margin="24" Spacing="8" VerticalAlignment="Center">
    <TextBlock Text="Widget Subscription" FontSize="18" FontWeight="SemiBold" />
    <TextBlock Text="Foundation skeleton. Tray widget and panel arrive in later tickets."
               TextWrapping="Wrap" Opacity="0.7" />
  </StackPanel>
</Window>
